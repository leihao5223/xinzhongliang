{
  "name": "xinzhongliang-fullstack",
  "version": "1.0.0",
  "private": true,
  "description": "Xin Zhongliang fullstack site using the Echofy visual template and Zhongliang business APIs.",
  "scripts": {
    "dev": "node --watch app/server/index.js",
    "start": "cross-env NODE_ENV=production node app/server/index.js",
    "server:dev": "npm --prefix app/server run dev",
    "server:start": "npm --prefix app/server run start"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "express": "^4.21.2",
    "iconv-lite": "^0.4.24",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.1"
  }
}
