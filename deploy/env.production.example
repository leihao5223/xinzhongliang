# 生产环境变量示例（与 systemd EnvironmentFile 配合）
# 复制到服务器 /srv/zhongliang/.env ， chmod 600 .env

NODE_ENV=production
PORT=3101

# 经 Nginx 反代时必设为 1，以便 HSTS 与 req.secure / IP 统计正确
TRUST_PROXY=1

# 仅本机监听（默认生产已是 127.0.0.1；若需公网直连 Node 可改为 0.0.0.0，不推荐）
LISTEN_HOST=127.0.0.1

JWT_SECRET=请替换为足够长的随机串
ADMIN_PASSWORD=请替换为强密码

# 仅在确认所有子域长期仅 HTTPS 后启用（见 docs/HTTPS-DEPLOY.md）
# HSTS_PRELOAD=1
