# 复制为 systemd drop-in 或合并进现有 zhongliang 单元。
# 路径：/etc/systemd/system/zhongliang.service.d/override.conf
#
# [Service]
# Environment=NODE_ENV=production
# Environment=PORT=3101
# Environment=TRUST_PROXY=1
# EnvironmentFile=-/srv/zhongliang/.env
#
# 然后: systemctl daemon-reload && systemctl restart zhongliang
